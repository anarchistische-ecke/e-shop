# Origin-side nginx for the storefront/CDN path.
# TLS terminates at Yandex CDN, so the VM origin listens on port 80 only.
# CDN rules must preserve origin Cache-Control for SSR HTML and force
# immutable caching only for fingerprinted /assets/* and image derivatives.

limit_req_zone $binary_remote_addr zone=storefront_auth:10m rate=10r/m;

server {
    listen 80;
    server_name www.yug-postel.ru;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), usb=(), fullscreen=(self), payment=(self)" always;
    return 301 https://yug-postel.ru$request_uri;
}

server {
    listen 80;
    server_name yug-postel.ru;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self' 'unsafe-inline' https://yookassa.ru https://*.yookassa.ru https://mc.yandex.ru https://mc.yandex.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://img.yug-postel.ru https://storage.yandexcloud.net https://*.storage.yandexcloud.net https://mc.yandex.ru https://mc.yandex.com; font-src 'self' data:; connect-src 'self' https://api.yug-postel.ru https://cms.yug-postel.ru https://img.yug-postel.ru https://yug-postel.ru https://yookassa.ru https://*.yookassa.ru https://mc.yandex.ru https://mc.yandex.com; frame-src 'self' https://yookassa.ru https://*.yookassa.ru; form-action 'self' https://yookassa.ru https://*.yookassa.ru; upgrade-insecure-requests" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), usb=(), fullscreen=(self), payment=(self)" always;

    location = /home {
        return 301 https://yug-postel.ru/$is_args$args;
    }

    location ~ ^/home(?<legacy_path>/.*)$ {
        return 301 https://yug-postel.ru$legacy_path$is_args$args;
    }

    location ^~ /auth/ {
        limit_req zone=storefront_auth burst=20 nodelay;
        proxy_pass http://127.0.0.1:8081/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;
        proxy_set_header X-Forwarded-Prefix /auth;
    }

    location = /robots.txt {
        include /etc/nginx/includes/eshop-storefront-upstream.conf;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;
    }

    location = /sitemap.xml {
        include /etc/nginx/includes/eshop-storefront-upstream.conf;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;
    }

    location = /silent-check-sso.html {
        include /etc/nginx/includes/eshop-storefront-upstream.conf;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;
    }

    location = /healthz {
        include /etc/nginx/includes/eshop-storefront-upstream.conf;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;
    }

    location ^~ /assets/ {
        include /etc/nginx/includes/eshop-storefront-upstream.conf;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;
    }

    location ^~ /legal-assets/ {
        include /etc/nginx/includes/eshop-storefront-upstream.conf;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;
    }

    location ^~ /legal-docs/ {
        include /etc/nginx/includes/eshop-storefront-upstream.conf;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;
    }

    location / {
        include /etc/nginx/includes/eshop-storefront-upstream.conf;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;
    }
}
