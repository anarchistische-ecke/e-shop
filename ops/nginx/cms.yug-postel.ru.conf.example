server {
    listen 80;
    server_name cms.yug-postel.ru;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name cms.yug-postel.ru;

    ssl_certificate /etc/letsencrypt/live/cms.yug-postel.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/cms.yug-postel.ru/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 50m;

    location / {
        include /etc/nginx/includes/eshop-cms-upstream.conf;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;
    }
}
