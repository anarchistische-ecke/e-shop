# Local Directus development settings
# Copy to .env before running docker compose.

# Keep this pinned to the current tested Directus release.
DIRECTUS_VERSION=11.17.2

# Used by Directus for crypto/session internals. Fine for local development; rotate if you prefer.
DIRECTUS_KEY=local-directus-key-please-change-if-needed
DIRECTUS_SECRET=local-directus-secret-please-change-if-needed

# Break-glass local admin created on first boot.
# Keep this separate from Keycloak editor/admin accounts so SSO users can be provisioned cleanly.
DIRECTUS_ADMIN_EMAIL=directus-admin@example.com
DIRECTUS_ADMIN_PASSWORD=Admin123!

# Public URL exposed by the local compose stack.
DIRECTUS_PUBLIC_URL=http://localhost:8055

# Optional admin token for schema snapshot/apply/check scripts.
# Leave empty locally unless you intentionally create a Directus static token for admin automation.
DIRECTUS_SCHEMA_ADMIN_TOKEN=

# Optional static token reused by the local backend for preview reads and CMS media metadata.
# Keep the real value only in directus/.env; never commit it.
DIRECTUS_STATIC_TOKEN=

# Local Keycloak SSO for Directus admin access.
DIRECTUS_AUTH_DISABLE_DEFAULT=false
DIRECTUS_AUTH_KEYCLOAK_CLIENT_ID=directus
DIRECTUS_AUTH_KEYCLOAK_CLIENT_SECRET=directus-local-secret
DIRECTUS_AUTH_KEYCLOAK_ISSUER_URL=http://keycloak.lvh.me:8081/realms/cozyhome/.well-known/openid-configuration
DIRECTUS_AUTH_KEYCLOAK_IDENTIFIER_KEY=email
DIRECTUS_AUTH_KEYCLOAK_ALLOW_PUBLIC_REGISTRATION=true
DIRECTUS_AUTH_KEYCLOAK_REQUIRE_VERIFIED_EMAIL=true
DIRECTUS_AUTH_KEYCLOAK_SYNC_USER_INFO=true
DIRECTUS_AUTH_KEYCLOAK_GROUP_CLAIM_NAME=groups
DIRECTUS_AUTH_KEYCLOAK_LABEL=Keycloak
DIRECTUS_AUTH_KEYCLOAK_ICON=vpn_key

# Stable Directus role ids used by the local Keycloak role mapping bootstrap.
DIRECTUS_ROLE_CMS_ADMIN_ID=4c4cc8d0-9b7f-4d56-84d2-1d64f5f10001
DIRECTUS_ROLE_CMS_EDITOR_ID=4c4cc8d0-9b7f-4d56-84d2-1d64f5f10002
DIRECTUS_ROLE_CMS_PUBLISHER_ID=4c4cc8d0-9b7f-4d56-84d2-1d64f5f10003
DIRECTUS_POLICY_CMS_ADMIN_ID=4c4cc8d0-9b7f-4d56-84d2-1d64f5f20001
DIRECTUS_POLICY_CMS_EDITOR_ID=4c4cc8d0-9b7f-4d56-84d2-1d64f5f20002
DIRECTUS_POLICY_CMS_PUBLISHER_ID=4c4cc8d0-9b7f-4d56-84d2-1d64f5f20003
DIRECTUS_ACCESS_CMS_ADMIN_ID=4c4cc8d0-9b7f-4d56-84d2-1d64f5f30001
DIRECTUS_ACCESS_CMS_EDITOR_ID=4c4cc8d0-9b7f-4d56-84d2-1d64f5f30002
DIRECTUS_ACCESS_CMS_PUBLISHER_ID=4c4cc8d0-9b7f-4d56-84d2-1d64f5f30003

# Final phase-1 collection allowlists for governance bootstrap.
DIRECTUS_CMS_CONTENT_COLLECTIONS=site_settings,navigation,navigation_items,page,page_sections,page_section_items,faq,legal_documents,banner,post
DIRECTUS_CMS_PUBLIC_COLLECTIONS=site_settings,navigation,navigation_items,page,page_sections,page_section_items,faq,legal_documents,banner,post
DIRECTUS_CMS_STATUS_FIELD=status

# Internal Directus database settings.
DIRECTUS_DB_DATABASE=directus
DIRECTUS_DB_USER=directus
DIRECTUS_DB_PASSWORD=directus

# Optional Directus API output cache backed by Redis.
# Keep disabled locally unless you want to test the extra cache layer.
DIRECTUS_DATA_CACHE_ENABLED=false
DIRECTUS_DATA_CACHE_TTL=5m
DIRECTUS_DATA_CACHE_AUTO_PURGE=true
DIRECTUS_DATA_CACHE_STORE=redis
DIRECTUS_DATA_CACHE_STATUS_HEADER=X-Directus-Cache
DIRECTUS_REDIS_URL=redis://cache:6379

# Local S3-compatible object storage settings.
# The local compose stack provisions a MinIO bucket and Directus uploads files there by default.
DIRECTUS_STORAGE_S3_KEY=minioadmin
DIRECTUS_STORAGE_S3_SECRET=minioadmin123
DIRECTUS_STORAGE_S3_BUCKET=directus
DIRECTUS_STORAGE_S3_REGION=us-east-1
DIRECTUS_STORAGE_S3_ENDPOINT=http://storage:9000
DIRECTUS_STORAGE_S3_FORCE_PATH_STYLE=true

# Raw public URL for the local MinIO bucket. Directus still serves assets through /assets as well.
DIRECTUS_STORAGE_PUBLIC_BASE_URL=http://localhost:9000/directus
