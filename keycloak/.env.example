# Local Keycloak development settings
# Copy to .env before running docker compose.

KEYCLOAK_IMAGE=keycloak-custom:25.0.5
KEYCLOAK_ADMIN=kcadmin
KEYCLOAK_ADMIN_PASSWORD=kcadmin
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_HOSTNAME=https://auth.yug-postel.ru
KEYCLOAK_HOSTNAME_BACKCHANNEL_DYNAMIC=true
KEYCLOAK_HOSTNAME_STRICT=true
KEYCLOAK_PROXY_HEADERS=xforwarded

# The backend uses this confidential client to create users and request
# Phase Two magic-link emails. Keep this in sync with api AUTH_MAGIC_LINK_*.
KEYCLOAK_MAGIC_LINK_SERVICE_CLIENT_ID=magic-link-service
KEYCLOAK_MAGIC_LINK_SERVICE_CLIENT_SECRET=magic-link-local-secret

# Directus CMS SSO session policy used by scripts/keycloak-directus-session-policy.sh.
KEYCLOAK_REALM=cozyhome
KEYCLOAK_DIRECTUS_CLIENT_ID=directus
KEYCLOAK_SSO_SESSION_IDLE_TIMEOUT=28800
KEYCLOAK_SSO_SESSION_MAX_LIFESPAN=43200
KEYCLOAK_SSO_SESSION_IDLE_TIMEOUT_REMEMBER_ME=2592000
KEYCLOAK_SSO_SESSION_MAX_LIFESPAN_REMEMBER_ME=7776000

# Yandex social login first broker policy used by scripts/keycloak-yandex-seamless-login.sh.
KEYCLOAK_YANDEX_IDP_ALIAS=yandex
KEYCLOAK_YANDEX_FIRST_BROKER_FLOW_ALIAS="yandex seamless first broker login"
KEYCLOAK_YANDEX_TRUST_EMAIL=true
