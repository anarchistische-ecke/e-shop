{
  "realm": "cozyhome",
  "enabled": true,
  "displayName": "Cozyhome Local",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "verifyEmail": false,
  "loginTheme": "postel-yug",
  "defaultRoles": [
    "offline_access",
    "uma_authorization"
  ],
  "roles": {
    "realm": [
      {
        "name": "admin"
      },
      {
        "name": "manager"
      },
      {
        "name": "customer"
      }
    ]
  },
  "clients": [
    {
      "clientId": "cozyhome-web",
      "name": "Cozyhome Web",
      "description": "Local storefront client",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": true,
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "acr-hardcoded",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "acr",
            "claim.value": "1",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin@example.com",
      "email": "admin@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Admin",
      "lastName": "Local",
      "credentials": [
        {
          "type": "password",
          "value": "Admin123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    },
    {
      "username": "manager@example.com",
      "email": "manager@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Manager",
      "lastName": "Local",
      "credentials": [
        {
          "type": "password",
          "value": "Manager123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "manager"
      ]
    },
    {
      "username": "customer@example.com",
      "email": "customer@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Customer",
      "lastName": "Local",
      "credentials": [
        {
          "type": "password",
          "value": "Customer123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "customer"
      ]
    }
  ]
}
